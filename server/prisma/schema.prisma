generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  farms     Farm[]
}

model Farm {
  id        String     @id @default(uuid())
  name      String
  ownerId   String
  owner     User       @relation(fields: [ownerId], references: [id])
  paddocks  Paddock[]
  createdAt DateTime   @default(now())
}

model Paddock {
  id        String   @id @default(uuid())
  name      String
  size      String?
  farmId    String
  farm      Farm     @relation(fields: [farmId], references: [id])
  sheep     Sheep[]
  createdAt DateTime @default(now())
}

model Sheep {
  id         String      @id @default(uuid())
  tag        String
  breed      String?
  weight     Float?
  paddockId  String
  paddock    Paddock     @relation(fields: [paddockId], references: [id])
  movements  Movement[]
  createdAt  DateTime    @default(now())
}

model Movement {
  id         String   @id @default(uuid())
  sheepId    String
  sheep      Sheep    @relation(fields: [sheepId], references: [id])
  fromPaddock String?
  toPaddock   String?
  createdAt  DateTime @default(now())
}
